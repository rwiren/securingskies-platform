# =============================================================================
# SecuringSkies Platform — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# Never commit .env to version control.
# =============================================================================

# --- MQTT Broker (required) --------------------------------------------------
# IP address or hostname of your Mosquitto broker.
# Use 127.0.0.1 for a local broker or the cloud address for remote ops.
MQTT_BROKER=192.168.192.100

# MQTT port. 1883 = plain TCP, 8883 = TLS (recommended for cloud).
MQTT_PORT=1883

# MQTT credentials — leave blank if your broker has no authentication.
MQTT_USERNAME=
MQTT_PASSWORD=

# --- Cesium Ion (required for 3D globe in web/server.py) --------------------
# Obtain a free token at https://ion.cesium.com/tokens
# Leave blank to fall back to OpenStreetMap 2D mode.
CESIUM_TOKEN=

# --- Artificial Intelligence ------------------------------------------------
# OpenAI API key — required when running with --cloud flag.
# Obtain at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Ollama base URL — required when running with local inference (default mode).
# Default is http://localhost:11434 if this variable is not set.
OLLAMA_HOST=http://localhost:11434

# --- Philips Hue (optional) -------------------------------------------------
# IP address of your Hue Bridge on the local network.
# Required only when running with the --hue flag.
# Discover your bridge at https://discovery.meethue.com/
HUE_BRIDGE_IP=192.168.1.228
